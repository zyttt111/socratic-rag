# ========================
# LLM API 配置
# ========================

# DeepSeek-V3（主力模型：1 元/百万 token）
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Claude Sonnet 4.5（苏格拉底反问 + 关系抽取）
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-5

# ========================
# Embedding 配置（本地免费）
# ========================
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
EMBEDDING_DEVICE=cpu          # cpu / cuda
EMBEDDING_DIM=1024

# Rerank（可选）
RERANK_MODEL=BAAI/bge-reranker-large
USE_RERANK=false

# ========================
# 数据库配置
# ========================
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=philosophy_chunks

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=phil_password

REDIS_URL=redis://localhost:6379/0

# ========================
# 抽取配置
# ========================
EXTRACTION_CONCURRENCY=20     # 并发 LLM 调用数
EXTRACTION_BATCH_SIZE=5       # 每批章节数
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# ========================
# 服务配置
# ========================
APP_ENV=development           # development / production
LOG_LEVEL=INFO
UI_PORT=8501
API_PORT=8000

# ========================
# 评估配置
# ========================
EVAL_BATCH_SIZE=10
EVAL_OUTPUT_DIR=docs/eval_reports